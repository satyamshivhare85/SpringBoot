<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->


    <bean id="myBean" class="org.example.Greeting">
    </bean>
    <bean id="EmailNotificationBean" class="org.looseCoupling.EmailNotification">
    </bean>
    <bean id="UserServices" class="org.looseCoupling.UserService">
    <property name="Notification" ref="EmailNotificationBean">
<!--        <consturcor-agr  &ndash;&gt; used for construction injection right now ref so we are using setter injection-->
        </property>
    </bean>



</beans>